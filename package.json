{
  "name": "memact-context",
  "private": true,
  "version": "0.0.0",
  "description": "Context category layer for turning app signals into user-readable Memact context proposals.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/engine.mjs",
  "exports": {
    ".": "./src/engine.mjs",
    "./lifecycle": "./src/lifecycle.mjs",
    "./cli": "./src/cli.mjs"
  },
  "keywords": [
    "memact",
    "context",
    "category-context",
    "schema-packets",
    "context",
    "deterministic",
    "evidence-induced",
    "memory"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Memact/Context.git"
  },
  "homepage": "https://github.com/Memact/Context",
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "memact-context": "./src/cli.mjs",
    "memact-schema": "./src/cli.mjs"
  },
  "scripts": {
    "check": "node ./scripts/check.mjs",
    "test": "node test/schema-packets.test.mjs && node test/news-articles.test.mjs",
    "context": "node ./src/cli.mjs",
    "schema": "node ./src/cli.mjs",
    "sample": "node ./src/cli.mjs --input examples/sample-inference-output.json --format report",
    "sample:json": "node ./src/cli.mjs --input examples/sample-inference-output.json --format json"
  }
}
